{
  "name": "neocombi",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "description": "Combinatorial test design tool. Modern reconstruction of PICT-PAPP, integrated with Microsoft PICT.",
  "type": "module",
  "bin": {
    "neocombi": "./bin/neocombi.mjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:cli": "node --import tsx/esm src/cli.ts --help > /dev/null",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "i18next": "^24.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^15.5.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.3"
  }
}
