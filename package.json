{
  "name": "neocombi",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "description": "Combinatorial test design tool. Modern reconstruction of PICT-PAPP, integrated with Microsoft PICT.",
  "type": "module",
  "bin": {
    "neocombi": "./bin/neocombi.mjs"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:cli": "node --import tsx/esm src/cli.ts --help > /dev/null",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage",
    "license:check": "license-checker --production --onlyAllow 'MIT;Apache-2.0;ISC;BSD-2-Clause;BSD-3-Clause;BlueOak-1.0.0;0BSD;CC0-1.0;Unlicense;MIT OR CC0-1.0' --excludePackages 'neocombi@0.1.0' --summary",
    "license:check:all": "license-checker --onlyAllow 'MIT;Apache-2.0;ISC;BSD-2-Clause;BSD-3-Clause;BlueOak-1.0.0;0BSD;CC0-1.0;Unlicense;MIT OR CC0-1.0;MIT AND CC-BY-3.0;MPL-2.0;Python-2.0;CC-BY-3.0;CC-BY-4.0' --excludePackages 'neocombi@0.1.0' --summary",
    "icons:build": "node scripts/genIcons.mjs",
    "demo:build": "node scripts/genDemoBundle.mjs"
  },
  "dependencies": {
    "i18next": "^24.2.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^15.5.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "happy-dom": "^15.11.7",
    "license-checker": "^25.0.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^3.2.3"
  }
}
